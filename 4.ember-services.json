    "topic": "Tournament service — getter topTeams (first 4 from standings)",
    "instruction": "How do I add a topTeams getter to a tournament service that returns the top 4 teams?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class TournamentService extends Service {\n  @tracked standings = [];\n\n  get topTeams() { return this.standings.slice(0, 4); }\n  get bottomTeams() { return this.standings.slice(-2); }\n  get leaderTeam() { return this.standings.at(0) ?? null; }\n\n  isQualified(teamId) {\n    return this.topTeams.some((team) => team.id === teamId);\n  }\n}\n```\n`slice(0, 4)` returns the first 4 without mutating. `slice(-2)` returns the last 2 (relegation zone). `isQualified` checks if a specific team is in the top 4 — useful for highlighting qualified teams."
  },
  {
    "id": 115,
    "layer": "syntax",
    "topic": "Favourites service — @tracked favouriteIds Set-workaround array",
    "instruction": "How do I store favourite IDs in a service using an array as a Set workaround for reactivity?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FavouritesService extends Service {\n  @tracked favouriteIds = [];\n\n  addFavourite(id) {\n    if (!this.favouriteIds.includes(id)) {\n      this.favouriteIds = [...this.favouriteIds, id];\n    }\n  }\n\n  removeFavourite(id) {\n    this.favouriteIds = this.favouriteIds.filter((fid) => fid !== id);\n  }\n\n  isFavourite(id) { return this.favouriteIds.includes(id); }\n  get count() { return this.favouriteIds.length; }\n}\n```\nGlimmer's `@tracked` does not track `Set` mutations — use an array instead. The `includes` check prevents duplicate IDs. Every write returns a new array reference maintaining reactivity."
  },
  {
    "id": 116,
    "layer": "syntax",
    "topic": "Favourites service — toggleFavourite(id) method",
    "instruction": "How do I write a toggleFavourite method in a favourites service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FavouritesService extends Service {\n  @tracked favouriteIds = [];\n\n  toggleFavourite(id) {\n    if (this.isFavourite(id)) {\n      this.favouriteIds = this.favouriteIds.filter((fid) => fid !== id);\n    } else {\n      this.favouriteIds = [...this.favouriteIds, id];\n    }\n  }\n\n  isFavourite(id) { return this.favouriteIds.includes(id); }\n}\n```\n`toggleFavourite` delegates to `isFavourite` for the check — no duplicate logic. Both branches create new array references. The calling component only needs one `@action` and one service method."
  },
  {
    "id": 117,
    "layer": "syntax",
    "topic": "Favourites service — isFavourite(id) method returns boolean",
    "instruction": "How do I write an isFavourite method with namespaced IDs to support multiple entity types?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FavouritesService extends Service {\n  @tracked favouriteIds = [];\n\n  isFavourite(id) { return this.favouriteIds.includes(String(id)); }\n  isFavouritePlayer(playerId) { return this.isFavourite(`player:${playerId}`); }\n  isFavouriteMatch(matchId) { return this.isFavourite(`match:${matchId}`); }\n}\n```\nConvert `id` to `String` to avoid type mismatches between numeric and string IDs. Namespacing with `player:` or `match:` prefixes allows storing favourites of different types in the same array without ID collisions."
  },
  {
    "id": 118,
    "layer": "syntax",
    "topic": "Favourites service — persist to localStorage, restore on init",
    "instruction": "How do I persist favourite IDs to localStorage and restore them when the service initializes?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nconst STORAGE_KEY = 'spordium:favourites';\n\nexport default class FavouritesService extends Service {\n  @tracked favouriteIds = [];\n\n  constructor(owner, args) {\n    super(owner, args);\n    try {\n      const stored = localStorage.getItem(STORAGE_KEY);\n      this.favouriteIds = stored ? JSON.parse(stored) : [];\n    } catch {\n      this.favouriteIds = [];\n    }\n  }\n\n  toggleFavourite(id) {\n    if (this.favouriteIds.includes(id)) {\n      this.favouriteIds = this.favouriteIds.filter((f) => f !== id);\n    } else {\n      this.favouriteIds = [...this.favouriteIds, id];\n    }\n    localStorage.setItem(STORAGE_KEY, JSON.stringify(this.favouriteIds));\n  }\n}\n```\n`constructor` restores favourites before first render. The `try-catch` handles corrupted JSON gracefully. Persist after every write to keep localStorage in sync. The constant `STORAGE_KEY` avoids magic strings."
  },
  {
    "id": 119,
    "layer": "syntax",
    "topic": "Search service — @tracked query, @tracked results, @tracked isSearching",
    "instruction": "How do I set up a search service with tracked query, results, and isSearching state?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class SearchService extends Service {\n  @tracked query = '';\n  @tracked results = [];\n  @tracked isSearching = false;\n  @tracked error = null;\n\n  get hasResults() { return this.results.length > 0; }\n  get isEmpty() {\n    return !this.isSearching && this.query.length > 0 && this.results.length === 0;\n  }\n\n  clearSearch() {\n    this.query = '';\n    this.results = [];\n    this.error = null;\n  }\n}\n```\nFour tracked properties cover all UI states: loading, empty query, results present, and error. `isEmpty` is true only when a search was performed but returned nothing — useful for 'No results found'. `clearSearch` resets all state atomically."
  },
  {
    "id": 120,
    "layer": "syntax",
    "topic": "Search service — search(query) restartable task",
    "instruction": "How do I write a restartable search task in a search service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task, timeout } from 'ember-concurrency';\n\nexport default class SearchService extends Service {\n  @tracked query = '';\n  @tracked results = [];\n\n  search = task({ restartable: true }, async (query) => {\n    this.query = query;\n    if (query.trim().length < 2) { this.results = []; return; }\n    await timeout(300);\n    const response = await fetch(`/api/search?q=${encodeURIComponent(query.trim())}`);\n    const { results } = await response.json();\n    this.results = results;\n  });\n}\n```\n`{ restartable: true }` cancels the previous search when a new one starts — ideal for search-as-you-type. The 300ms `timeout` acts as a debounce. Minimum 2 character guard prevents noisy searches."
  },
  {
    "id": 121,
    "layer": "syntax",
    "topic": "Search service — clearSearch() method",
    "instruction": "How do I write a clearSearch method that resets all search state?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class SearchService extends Service {\n  @tracked query = '';\n  @tracked results = [];\n  @tracked isSearching = false;\n\n  clearSearch() {\n    this.query = '';\n    this.results = [];\n    this.isSearching = false;\n    this.search?.cancelAll?.();\n  }\n\n  get hasQuery() { return this.query.trim().length > 0; }\n}\n```\n`cancelAll()` stops any in-flight search request, preventing stale results from appearing after clear. Optional chaining `?.` makes this safe even before the task is defined. Clearing `isSearching` prevents a stuck loading state."
  },
  {
    "id": 122,
    "layer": "syntax",
    "topic": "Filter service — @tracked activeFilters object",
    "instruction": "How do I create a filter service with a @tracked activeFilters object?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FilterService extends Service {\n  @tracked activeFilters = {\n    team: null,\n    venue: null,\n    season: null,\n    matchType: null,\n  };\n\n  get hasActiveFilters() {\n    return Object.values(this.activeFilters).some((v) => v !== null);\n  }\n\n  get activeFilterCount() {\n    return Object.values(this.activeFilters).filter((v) => v !== null).length;\n  }\n}\n```\nInitializing with null values for all known filter keys makes the shape explicit. `Object.values` plus `some` efficiently checks if any filter is active. `activeFilterCount` drives a badge showing '3 filters applied'."
  },
  {
    "id": 123,
    "layer": "syntax",
    "topic": "Filter service — setFilter(key, value) method",
    "instruction": "How do I write a setFilter method in a filter service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FilterService extends Service {\n  @tracked activeFilters = {};\n\n  setFilter(key, value) {\n    this.activeFilters = { ...this.activeFilters, [key]: value ?? null };\n  }\n\n  removeFilter(key) { this.setFilter(key, null); }\n  getFilter(key) { return this.activeFilters[key] ?? null; }\n}\n```\nSpread syntax creates a new object reference — required for Glimmer reactivity. Setting a filter to `null` effectively removes it so `removeFilter` delegates to `setFilter(key, null)`. `getFilter` provides safe read access."
  },
  {
    "id": 124,
    "layer": "syntax",
    "topic": "Filter service — clearFilters() method",
    "instruction": "How do I write a clearFilters method on a filter service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FilterService extends Service {\n  @tracked activeFilters = {};\n\n  clearFilters() { this.activeFilters = {}; }\n\n  clearFilter(key) {\n    const { [key]: _removed, ...rest } = this.activeFilters;\n    this.activeFilters = rest;\n  }\n\n  resetToDefaults() {\n    this.activeFilters = { matchType: 'T20', season: '2025' };\n  }\n}\n```\nAssigning `{}` replaces the entire filters object in one operation. `clearFilter(key)` uses destructuring with rest to remove a single key immutably — no `delete` which mutates. `resetToDefaults` sets sensible starting filters."
  },
  {
    "id": 125,
    "layer": "syntax",
    "topic": "Filter service — getter hasActiveFilters boolean",
    "instruction": "How do I write a hasActiveFilters getter in a filter service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class FilterService extends Service {\n  @tracked activeFilters = {};\n\n  get hasActiveFilters() {\n    return Object.keys(this.activeFilters).length > 0;\n  }\n\n  get filterSummary() {\n    const entries = Object.entries(this.activeFilters);\n    if (entries.length === 0) return 'No filters';\n    return entries.map(([key, value]) => `${key}: ${value}`).join(', ');\n  }\n\n  get filterCount() { return Object.keys(this.activeFilters).length; }\n}\n```\n`Object.keys` checks how many filter keys exist. `filterSummary` builds a human-readable string like `'team: India, season: 2025'` for display in a chips/tags UI. All getters read `@tracked activeFilters` and recompute when filters change."
  },
  {
    "id": 126,
    "layer": "syntax",
    "topic": "Pagination service — @tracked currentPage, @tracked totalPages",
    "instruction": "How do I create a pagination service with @tracked currentPage and totalPages?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class PaginationService extends Service {\n  @tracked currentPage = 1;\n  @tracked totalPages = 1;\n  @tracked pageSize = 20;\n  @tracked totalItems = 0;\n\n  get isFirstPage() { return this.currentPage === 1; }\n  get isLastPage() { return this.currentPage >= this.totalPages; }\n\n  setMeta({ totalItems, pageSize }) {\n    this.totalItems = totalItems;\n    this.pageSize = pageSize;\n    this.totalPages = Math.ceil(totalItems / pageSize);\n  }\n}\n```\n`setMeta` computes `totalPages` from API response metadata. `isFirstPage` and `isLastPage` drive disabled state of prev/next buttons. `totalItems` allows showing 'Showing 20 of 500 matches' in the UI."
  },
  {
    "id": 127,
    "layer": "syntax",
    "topic": "Pagination service — nextPage() / prevPage() methods",
    "instruction": "How do I write nextPage and prevPage methods in a pagination service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class PaginationService extends Service {\n  @tracked currentPage = 1;\n  @tracked totalPages = 1;\n\n  nextPage() { if (this.currentPage < this.totalPages) this.currentPage += 1; }\n  prevPage() { if (this.currentPage > 1) this.currentPage -= 1; }\n\n  get canGoNext() { return this.currentPage < this.totalPages; }\n  get canGoPrev() { return this.currentPage > 1; }\n}\n```\nBoth methods guard against going out of bounds. `canGoNext` and `canGoPrev` drive the `disabled` attribute of navigation buttons, keeping the template declarative."
  },
  {
    "id": 128,
    "layer": "syntax",
    "topic": "Pagination service — goToPage(n) method with bounds check",
    "instruction": "How do I write a goToPage method with bounds checking in a pagination service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class PaginationService extends Service {\n  @tracked currentPage = 1;\n  @tracked totalPages = 1;\n\n  goToPage(page) {\n    this.currentPage = Math.max(1, Math.min(page, this.totalPages));\n  }\n\n  goToFirst() { this.currentPage = 1; }\n  goToLast() { this.currentPage = this.totalPages; }\n}\n```\n`Math.max(1, Math.min(page, totalPages))` clamps the value in one expression. Safer than throwing since page numbers often come from URL params or user input that may be out of range."
  },
  {
    "id": 129,
    "layer": "syntax",
    "topic": "Pagination service — getter pageRange array for display",
    "instruction": "How do I add a pageRange getter to a pagination service for rendering page number buttons?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class PaginationService extends Service {\n  @tracked currentPage = 1;\n  @tracked totalPages = 1;\n\n  get pageRange() {\n    const delta = 2;\n    const left = Math.max(1, this.currentPage - delta);\n    const right = Math.min(this.totalPages, this.currentPage + delta);\n    const range = [];\n    for (let i = left; i <= right; i++) range.push(i);\n    return range;\n  }\n\n  get showLeftEllipsis() { return this.currentPage > 3; }\n  get showRightEllipsis() { return this.currentPage < this.totalPages - 2; }\n}\n```\n`pageRange` returns page numbers within 2 of the current page — e.g., on page 5 of 10: `[3, 4, 5, 6, 7]`. `showLeftEllipsis` and `showRightEllipsis` tell the template when to render `...`."
  },
  {
    "id": 130,
    "layer": "syntax",
    "topic": "Commentary service — @tracked comments array, addComment() method",
    "instruction": "How do I build a commentary service with a @tracked comments array and addComment method?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class CommentaryService extends Service {\n  @tracked comments = [];\n\n  addComment(comment) {\n    const exists = this.comments.some((c) => c.id === comment.id);\n    if (!exists) this.comments = [comment, ...this.comments];\n  }\n\n  get latestComment() { return this.comments.at(0) ?? null; }\n  get commentCount() { return this.comments.length; }\n}\n```\nPrepending new comments (newest first) matches live commentary feed conventions. The duplicate check by `id` prevents the same ball appearing twice when polling. `latestComment` is used by ticker components."
  },
  {
    "id": 131,
    "layer": "syntax",
    "topic": "Commentary service — fetch comments task, polling with restartable",
    "instruction": "How do I write a polling task in a commentary service that fetches new comments regularly?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task, timeout } from 'ember-concurrency';\n\nexport default class CommentaryService extends Service {\n  @tracked comments = [];\n\n  pollComments = task({ restartable: true }, async (matchId) => {\n    while (true) {\n      const response = await fetch(`/api/matches/${matchId}/commentary`);\n      const { comments } = await response.json();\n      const existingIds = new Set(this.comments.map((c) => c.id));\n      const newComments = comments.filter((c) => !existingIds.has(c.id));\n      if (newComments.length > 0) this.comments = [...newComments, ...this.comments];\n      await timeout(8000);\n    }\n  });\n\n  stopPolling() { this.pollComments.cancelAll(); }\n}\n```\nUsing a `Set` for existing IDs makes the duplicate check O(1). Only prepend new comments. `restartable` means re-calling `perform(matchId)` cancels the old loop and starts fresh."
  },
  {
    "id": 132,
    "layer": "syntax",
    "topic": "Commentary service — getter latestComment",
    "instruction": "How do I write a latestComment getter in a commentary service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class CommentaryService extends Service {\n  @tracked comments = [];\n\n  get latestComment() { return this.comments.at(0) ?? null; }\n  get latestBallDescription() { return this.latestComment?.description ?? 'Waiting for commentary...'; }\n  get latestOver() { return this.latestComment?.over ?? null; }\n  get isLastBallWicket() { return this.latestComment?.isWicket === true; }\n}\n```\n`Array.at(0)` is the modern way to get the first element. All getters use optional chaining for safe access when `latestComment` is null. `isLastBallWicket` drives wicket animations in cricket apps."
  },
  {
    "id": 133,
    "layer": "syntax",
    "topic": "Lineup service — @tracked lineup array",
    "instruction": "How do I set up a lineup service with a @tracked lineup array?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class LineupService extends Service {\n  @tracked lineup = [];\n\n  get playerCount() { return this.lineup.length; }\n  get isValid() { return this.lineup.length === 11; }\n  get batsmen() { return this.lineup.filter((p) => p.role === 'batsman'); }\n  get bowlers() { return this.lineup.filter((p) => p.role === 'bowler'); }\n}\n```\nAn empty array default allows safe `#each` in templates. `isValid` enforces the 11-player cricket rule. `batsmen` and `bowlers` filter reactively — no need for separate tracked arrays for each role."
  },
  {
    "id": 134,
    "layer": "syntax",
    "topic": "Lineup service — addPlayer() / removePlayer() methods",
    "instruction": "How do I write addPlayer and removePlayer methods on a lineup service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class LineupService extends Service {\n  @tracked lineup = [];\n\n  addPlayer(player) {\n    if (this.lineup.length >= 11) return false;\n    if (this.lineup.some((p) => p.id === player.id)) return false;\n    this.lineup = [...this.lineup, player];\n    return true;\n  }\n\n  removePlayer(playerId) {\n    this.lineup = this.lineup.filter((p) => p.id !== playerId);\n  }\n}\n```\n`addPlayer` returns `false` for both failure cases (full or duplicate) so calling components can show feedback. The 11-player cap enforces cricket rules. `removePlayer` uses `filter` for an immutable new array."
  },
  {
    "id": 135,
    "layer": "syntax",
    "topic": "Lineup service — reorderPlayer(from, to) method",
    "instruction": "How do I write a reorderPlayer method in a lineup service for drag-and-drop reordering?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class LineupService extends Service {\n  @tracked lineup = [];\n\n  reorderPlayer(fromIndex, toIndex) {\n    const len = this.lineup.length;\n    if (fromIndex < 0 || toIndex < 0 || fromIndex >= len || toIndex >= len) return;\n    const newLineup = [...this.lineup];\n    const [moved] = newLineup.splice(fromIndex, 1);\n    newLineup.splice(toIndex, 0, moved);\n    this.lineup = newLineup;\n  }\n}\n```\nBounds-check both indices first. Copy with spread to avoid mutating the original. `splice` removes from `fromIndex` and inserts at `toIndex`. Assign back to `this.lineup` to trigger reactivity."
  },
  {
    "id": 136,
    "layer": "syntax",
    "topic": "Lineup service — submit lineup task (drop)",
    "instruction": "How do I write a drop task in a lineup service to submit the lineup to the API?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task } from 'ember-concurrency';\n\nexport default class LineupService extends Service {\n  @tracked lineup = [];\n  @tracked submitError = null;\n\n  submitLineup = task({ drop: true }, async (matchId) => {\n    if (this.lineup.length !== 11) throw new Error('Lineup must have exactly 11 players');\n    this.submitError = null;\n    try {\n      const response = await fetch(`/api/matches/${matchId}/lineup`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ players: this.lineup.map((p) => p.id) }),\n      });\n      if (!response.ok) throw new Error('Submission failed');\n    } catch (err) {\n      this.submitError = err.message;\n      throw err;\n    }\n  });\n}\n```\n`{ drop: true }` prevents double-submission — clicking submit while a submission is in progress is a no-op. Only player IDs are sent. `submitError` is set for UI display while also re-throwing so the component can catch it."
  },
  {
    "id": 137,
    "layer": "syntax",
    "topic": "Stats service — fetchPlayerStats(playerId) task, memoize results",
    "instruction": "How do I write a fetchPlayerStats task that memoizes results by player ID?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task } from 'ember-concurrency';\n\nexport default class StatsService extends Service {\n  @tracked statsCache = {};\n\n  fetchPlayerStats = task(async (playerId) => {\n    if (this.statsCache[playerId]) return this.statsCache[playerId];\n    const response = await fetch(`/api/players/${playerId}/stats`);\n    const stats = await response.json();\n    this.statsCache = { ...this.statsCache, [playerId]: stats };\n    return stats;\n  });\n}\n```\nReturn early from cache to avoid redundant calls. Spread to update `@tracked` object immutably. Since the service is a singleton, multiple components requesting the same player's stats share the cached result."
  },
  {
    "id": 138,
    "layer": "syntax",
    "topic": "Stats service — @tracked statsCache object (id → stats map)",
    "instruction": "How do I manage a @tracked statsCache object in a stats service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class StatsService extends Service {\n  @tracked statsCache = {};\n\n  setStats(playerId, stats) {\n    this.statsCache = { ...this.statsCache, [playerId]: stats };\n  }\n\n  getStats(playerId) { return this.statsCache[playerId] ?? null; }\n\n  hasStats(playerId) {\n    return Object.prototype.hasOwnProperty.call(this.statsCache, playerId);\n  }\n\n  invalidateStats(playerId) {\n    const { [playerId]: _removed, ...rest } = this.statsCache;\n    this.statsCache = rest;\n  }\n\n  clearCache() { this.statsCache = {}; }\n}\n```\n`Object.prototype.hasOwnProperty.call` is safer than `in` which checks the prototype chain. `invalidateStats` uses destructuring rest to remove a key immutably — critical after a stats update to force fresh data on next fetch."
  },
  {
    "id": 139,
    "layer": "syntax",
    "topic": "Stats service — getter for a specific player's stats",
    "instruction": "How do I write a getter in a stats service to access a specific player's cached stats?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class StatsService extends Service {\n  @tracked statsCache = {};\n  @tracked focusedPlayerId = null;\n\n  setFocusedPlayer(playerId) { this.focusedPlayerId = playerId; }\n\n  get focusedPlayerStats() {\n    if (!this.focusedPlayerId) return null;\n    return this.statsCache[this.focusedPlayerId] ?? null;\n  }\n\n  get focusedPlayerAverage() { return this.focusedPlayerStats?.batting?.average ?? 0; }\n  get focusedPlayerStrikeRate() { return this.focusedPlayerStats?.batting?.strikeRate ?? 0; }\n}\n```\n`focusedPlayerId` is tracked so changing the focused player triggers reactive updates to `focusedPlayerStats` and derived getters. Optional chaining handles missing nested stats gracefully."
  },
  {
    "id": 140,
    "layer": "syntax",
    "topic": "Venue service — @tracked venues array, fetchVenues() task",
    "instruction": "How do I create a venue service with a @tracked venues array and fetchVenues task?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task } from 'ember-concurrency';\n\nexport default class VenueService extends Service {\n  @tracked venues = [];\n  @tracked isLoaded = false;\n\n  fetchVenues = task(async () => {\n    if (this.isLoaded) return;\n    const response = await fetch('/api/venues');\n    const { venues } = await response.json();\n    this.venues = venues;\n    this.isLoaded = true;\n  });\n\n  get venueCount() { return this.venues.length; }\n}\n```\n`isLoaded` flag prevents duplicate fetches — venue data rarely changes so fetching once per session is sufficient. The guard returns early if data is already available."
  },
  {
    "id": 141,
    "layer": "syntax",
    "topic": "Venue service — getVenueById(id) method (from cache)",
    "instruction": "How do I write a getVenueById method that looks up venues from the cached array?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class VenueService extends Service {\n  @tracked venues = [];\n\n  getVenueById(id) {\n    return this.venues.find((v) => String(v.id) === String(id)) ?? null;\n  }\n\n  getVenuesByCity(city) {\n    return this.venues.filter((v) => v.city?.toLowerCase() === city.toLowerCase());\n  }\n\n  get venueNames() { return this.venues.map((v) => v.name); }\n}\n```\n`String(v.id) === String(id)` coerces both sides to avoid numeric vs string ID mismatches. `getVenuesByCity` is case-insensitive. `venueNames` is useful for populating a dropdown select."
  },
  {
    "id": 142,
    "layer": "syntax",
    "topic": "Countdown service — @tracked secondsLeft, start(targetDate) task",
    "instruction": "How do I build a countdown service that counts down to a target date?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task, timeout } from 'ember-concurrency';\n\nexport default class CountdownService extends Service {\n  @tracked secondsLeft = 0;\n\n  start = task(async (targetDate) => {\n    while (true) {\n      const now = Date.now();\n      const end = new Date(targetDate).getTime();\n      this.secondsLeft = Math.max(0, Math.floor((end - now) / 1000));\n      if (this.secondsLeft === 0) break;\n      await timeout(1000);\n    }\n  });\n\n  stop() {\n    this.start.cancelAll();\n    this.secondsLeft = 0;\n  }\n}\n```\nRe-calculate from `Date.now()` on each tick to self-correct for timer drift. `Math.max(0, ...)` clamps to 0. Breaking out of the loop when seconds hit 0 stops the task automatically."
  },
  {
    "id": 143,
    "layer": "syntax",
    "topic": "Countdown service — stop() method (cancelAll)",
    "instruction": "How do I write a stop method on a countdown service that cancels the task and resets?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\nimport { task } from 'ember-concurrency';\n\nexport default class CountdownService extends Service {\n  @tracked secondsLeft = 0;\n  @tracked isRunning = false;\n\n  start = task(async (targetDate) => {\n    this.isRunning = true;\n    try {\n      while (true) {\n        this.secondsLeft = Math.max(0, Math.floor((new Date(targetDate) - Date.now()) / 1000));\n        if (this.secondsLeft === 0) break;\n        const { timeout } = await import('ember-concurrency');\n        await timeout(1000);\n      }\n    } finally {\n      this.isRunning = false;\n    }\n  });\n\n  stop() { this.start.cancelAll(); this.secondsLeft = 0; }\n\n  willDestroy() { super.willDestroy(); this.stop(); }\n}\n```\n`cancelAll()` cancels all running instances. `isRunning` uses `finally` to reset cleanly on both finish and cancellation. `willDestroy` stops the countdown when the service tears down."
  },
  {
    "id": 144,
    "layer": "syntax",
    "topic": "Countdown service — getter formattedTime (mm:ss)",
    "instruction": "How do I add a formattedTime getter to a countdown service that returns mm:ss format?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class CountdownService extends Service {\n  @tracked secondsLeft = 0;\n\n  get formattedTime() {\n    const hours = Math.floor(this.secondsLeft / 3600);\n    const minutes = Math.floor((this.secondsLeft % 3600) / 60);\n    const seconds = this.secondsLeft % 60;\n    const mm = String(minutes).padStart(2, '0');\n    const ss = String(seconds).padStart(2, '0');\n    return hours > 0 ? `${hours}:${mm}:${ss}` : `${mm}:${ss}`;\n  }\n\n  get isUrgent() { return this.secondsLeft > 0 && this.secondsLeft <= 60; }\n}\n```\n`padStart(2, '0')` zero-pads single digits. Conditionally showing hours avoids `00:05:30` for short countdowns. `isUrgent` is true in the final 60 seconds — use it to switch text color to red in cricket pre-match timers."
  },
  {
    "id": 145,
    "layer": "syntax",
    "topic": "Undo service — @tracked history array, push(snapshot) method",
    "instruction": "How do I create an undo service with a @tracked history array and push method?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nconst MAX_HISTORY = 50;\n\nexport default class UndoService extends Service {\n  @tracked history = [];\n\n  push(snapshot) {\n    const next = [...this.history, snapshot];\n    this.history = next.length > MAX_HISTORY ? next.slice(-MAX_HISTORY) : next;\n  }\n\n  get canUndo() { return this.history.length > 0; }\n  get historySize() { return this.history.length; }\n}\n```\nCap history at 50 entries to prevent unbounded memory growth. `snapshot` should be a plain serializable object (e.g., a copy of lineup state). `canUndo` drives the disabled state of the undo button."
  },
  {
    "id": 146,
    "layer": "syntax",
    "topic": "Undo service — undo() method, pop and return snapshot",
    "instruction": "How do I write an undo method that removes and returns the latest snapshot?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class UndoService extends Service {\n  @tracked history = [];\n\n  push(snapshot) { this.history = [...this.history, snapshot]; }\n\n  undo() {\n    if (!this.canUndo) return null;\n    const snapshot = this.history.at(-1);\n    this.history = this.history.slice(0, -1);\n    return snapshot;\n  }\n\n  get canUndo() { return this.history.length > 0; }\n}\n```\nRead the last item with `.at(-1)` then create a new array excluding it with `.slice(0, -1)`. Fully immutable — no `pop()` mutation. The caller receives the snapshot and restores state from it. Returns `null` when history is empty."
  },
  {
    "id": 147,
    "layer": "syntax",
    "topic": "Undo service — getter canUndo boolean",
    "instruction": "How do I write canUndo and canRedo getters in an undo service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class UndoService extends Service {\n  @tracked history = [];\n  @tracked future = [];\n\n  get canUndo() { return this.history.length > 0; }\n  get canRedo() { return this.future.length > 0; }\n  get undoCount() { return this.history.length; }\n\n  get undoTooltip() {\n    return this.canUndo\n      ? `Undo (${this.undoCount} steps available)`\n      : 'Nothing to undo';\n  }\n}\n```\n`canUndo` and `canRedo` are simple boolean getters that read tracked arrays. `undoTooltip` composes a user-facing string for `title` attributes on undo buttons in a cricket score editor."
  },
  {
    "id": 148,
    "layer": "syntax",
    "topic": "Error tracking service — logError(error, context) method",
    "instruction": "How do I write a logError method in an error tracking service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class ErrorTrackingService extends Service {\n  @tracked lastError = null;\n  @tracked errorCount = 0;\n\n  logError(error, context = {}) {\n    this.lastError = { error, context, timestamp: Date.now() };\n    this.errorCount += 1;\n    console.error('[ErrorTracking]', error, context);\n    this._sendToServer(error, context);\n  }\n\n  _sendToServer(error, context) {\n    fetch('/api/errors', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ message: error.message, stack: error.stack, context }),\n    }).catch(() => {}); // swallow errors to avoid infinite loops\n  }\n}\n```\n`_sendToServer` swallows its own fetch errors — an error reporter must never throw. `lastError` and `errorCount` are `@tracked` for a global error banner. `context` accepts arbitrary data like `{ matchId, action: 'submitLineup' }`."
  },
  {
    "id": 149,
    "layer": "syntax",
    "topic": "Error tracking service — @tracked lastError, clearError() method",
    "instruction": "How do I add a clearError method and lastError property to an error tracking service?",
    "response": "```js\nimport Service from '@ember/service';\nimport { tracked } from '@glimmer/tracking';\n\nexport default class ErrorTrackingService extends Service {\n  @tracked lastError = null;\n  @tracked errors = [];\n\n  get hasError() { return this.lastError !== null; }\n  get errorMessage() { return this.lastError?.error?.message ?? null; }\n\n  clearError() { this.lastError = null; }\n  clearAllErrors() { this.lastError = null; this.errors = []; }\n}\n```\n`clearError` is called by the dismiss button on a global error banner. `hasError` drives conditional rendering. `errorMessage` safely extracts the message string. Keeping `errors` as an array allows an error history panel for debugging."
  },
